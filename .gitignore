# ==============================================================================
# svg2htmlsvg .gitignore
# ==============================================================================

# --- Zsh compiled files ---
*.zwc

# --- Editor and IDE ---
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- OS-generated ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Configuration files (user-specific, not repo defaults) ---
# Don't track personal config overrides
svg2htmlsvg.conf
.svg2htmlsvg.conf

# --- Temporary and output files ---
*.tmp
*.bak
*.orig
*.log

# --- Test artifacts ---
test/output/
test/tmp/
